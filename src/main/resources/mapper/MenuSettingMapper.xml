<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.MenuSettingMapper">

    <resultMap id="BaseResultMap" type="com.example.demo.model.MenuSetting">
        <result column="menu_id" jdbcType="BIGINT" property="menuId"/>
        <result column="required" jdbcType="BOOLEAN" property="required"/>
    </resultMap>

    <sql id="Base_Column_List">menu_id
    , required</sql>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM menu_settings ORDER BY menu_id
    </select>

    <select id="selectByMenuId" parameterType="long" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM menu_settings WHERE menu_id = #{menuId}
    </select>

    <insert id="upsert" parameterType="com.example.demo.model.MenuSetting">
        INSERT INTO
            menu_settings (menu_id, required)
        VALUES
            (#{menuId}, #{required}) ON CONFLICT (menu_id)
        DO
        UPDATE SET required = EXCLUDED.required, updated_at = now()
    </insert>

</mapper>

